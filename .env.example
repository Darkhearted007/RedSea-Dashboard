# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ─── AIS WebSocket ────────────────────────────────────────────────────────────
# Your AIS data source WebSocket URL
# For local mock server: ws://localhost:3001
# For production: wss://your-ais-provider.com/stream
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── API Backend ──────────────────────────────────────────────────────────────
# Base URL for REST API calls
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── WebSocket Security ───────────────────────────────────────────────────────
# Secret used to sign auth tokens for the secure AIS stream
# Generate with: openssl rand -hex 32
WS_AUTH_SECRET=your_ws_auth_secret_here

# ─── Optional: Sanctions API ──────────────────────────────────────────────────
# OFAC API key for live sanctions screening (optional — falls back to static DB)
# OFAC_API_KEY=your_ofac_api_key_here
